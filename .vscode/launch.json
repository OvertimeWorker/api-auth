{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Express (nodemon)",
      "runtimeExecutable": "nodemon",
      "program": "${workspaceFolder}/src/server.ts",
      "restart": true,
      "console": "integratedTerminal",
      "runtimeArgs": [
        "--exec",
        "node -r ts-node/register"
      ]
    }
  ]
}