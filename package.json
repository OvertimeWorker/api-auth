{
  "name": "overtime-worker-api-auth",
  "version": "1.0.0",
  "license": "GPL-3.0",
  "author": "wjnotl",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:create": "prisma migrate dev --create-only",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "prisma:seed": "prisma db seed",
    "prisma:setup": "prisma generate && prisma migrate dev && prisma db seed",
    "prisma:studio": "prisma studio",
    "start": "node dist/server.js",
    "test": "cross-env NODE_ENV=test node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "cross-env NODE_ENV=test node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "discover-paths": "pnpm build && cross-env DISCOVER_PATH=true node --no-warnings --experimental-vm-modules dist/scripts/discover-paths.script.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "dotenv": "17.4.1",
    "express": "5.2.1",
    "http-status-codes": "2.3.0",
    "morgan": "1.10.1",
    "overtime-worker-api-utils": "git+ssh://git@github.com/OvertimeWorker/api-utils.git#v1.0.9"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.3.0",
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/morgan": "1.9.10",
    "@types/node": "25.6.0",
    "@types/pluralize": "0.0.33",
    "@types/supertest": "7.2.0",
    "cross-env": "10.1.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.3.0",
    "jest-mock-extended": "4.0.0",
    "pluralize": "8.0.0",
    "prisma": "7.5.0",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "esbuild",
      "unrs-resolver",
      "overtime-worker-api-utils"
    ],
    "overrides": {
      "jest-mock-extended>typescript": "6.0.3"
    }
  }
}
